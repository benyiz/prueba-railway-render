generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model pokemons {
  id     Int    @id @default(autoincrement())
  nombre String @db.VarChar(100)
}

model users {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
}